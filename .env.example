# Optional: Set Firebase service account path via environment variable
# If not set, the system will search default locations:
# - firebase_service_account.json (in project root)
# - config/firebase_service_account.json
# - ~/.config/firebase_service_account.json

# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/your/firebase_service_account.json

# Telegram Bot Configuration (for notifications)
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# SMTP Email Configuration (for sending weekly reports)
# 163.com example settings:
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_email@163.com
SMTP_PASSWORD=your_smtp_password
SMTP_USE_SSL=1
SMTP_USE_TLS=0

# Email Recipients (comma-separated)
EMAIL_RECIPIENTS=recipient@example.com,another@example.com

# Alternative: Resend API (instead of SMTP)
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_TO=recipient@example.com,another@example.com

# Optional: OpenAI API for enhanced summaries
# OPENAI_API_KEY=sk-xxxxx
